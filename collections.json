{
  "info": {
    "_postman_id": "38f1503e-ea4c-4759-b988-2dc9196b2971",
    "name": "E2E API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has a JWT token', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('token');",
              "  pm.environment.set('jwt_token', jsonData.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Create Dish",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const uniqueName = `E2E Automated Burger ${Date.now()}`;",
              "pm.environment.set('dish_name', uniqueName);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Item successfully created (201)', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Created dish name matches request variable', function () {",
              "  const jsonData = pm.response.json();",
              "  pm.expect(jsonData.name).to.eql(pm.environment.get('dish_name'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{jwt_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{dish_name}}\",\n  \"price\": 300,\n  \"category\": \"Main Course\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/dishes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "dishes"
          ]
        }
      }
    },
    {
      "name": "3) Get Dishes and Verify Created Item",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/dishes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "dishes"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Created dish exists in list', function () {",
              "  const list = pm.response.json();",
              "  const createdName = pm.environment.get('dish_name');",
              "  const found = Array.isArray(list) && list.some(d => d.name === createdName);",
              "  pm.expect(found).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}